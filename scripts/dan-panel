#!/bin/sh
# DAN menu-bar panel launcher (PANEL_CONTRACT §5).
#
# Thin client: renders the static cockpit assets in a native popover and
# talks to dand over HTTP/WS only. Requires the panel extra:
#   .venv/bin/pip install -e '.[panel]'
set -eu

if [ -z "${DAN_REPO:-}" ]; then
  DAN_REPO="$(cd "$(dirname "$0")/.." && pwd)"
fi

PYTHON="$DAN_REPO/.venv/bin/python"
if [ ! -x "$PYTHON" ]; then
  PYTHON="$(command -v python3)"
fi

# Config resolution mirrors scripts/dand: explicit DAN_CONFIG wins;
# otherwise prefer the user-owned config outside the repo.
if [ -z "${DAN_CONFIG:-}" ] && [ -f "$HOME/.dan/config.toml" ]; then
  DAN_CONFIG="$HOME/.dan/config.toml"
  export DAN_CONFIG
fi

if [ -n "${DAN_CONFIG:-}" ]; then
  DAN_CONFIG_REAL="$("$PYTHON" - "$DAN_CONFIG" <<'PY'
import sys
from pathlib import Path

print(Path(sys.argv[1]).expanduser().resolve(strict=False))
PY
)"
  DAN_EXAMPLE_REAL="$("$PYTHON" - "$DAN_REPO/config/dan.example.toml" <<'PY'
import sys
from pathlib import Path

print(Path(sys.argv[1]).expanduser().resolve(strict=False))
PY
)"
  if [ "$DAN_CONFIG_REAL" = "$DAN_EXAMPLE_REAL" ]; then
    echo "config/dan.example.toml is not a runtime config." >&2
    echo "Use ~/.dan/config.toml or $DAN_REPO/config/dan.toml." >&2
    exit 1
  fi
fi

exec "$PYTHON" -m dan.panel.menubar_app "$@"
