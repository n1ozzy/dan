#!/bin/sh
# Jarvis daemon entry wrapper (LAUNCH_SUPERVISION.md §5).
#
# Run by hand from the repo, or installed to ~/.jarvis/bin/jarvisd by
# scripts/install-launchd.sh (which pins JARVIS_REPO to an absolute path,
# because launchd cannot resolve paths relative to this repo).
set -eu

if [ -z "${JARVIS_REPO:-}" ]; then
  JARVIS_REPO="$(cd "$(dirname "$0")/.." && pwd)"
fi

PYTHON="$JARVIS_REPO/.venv/bin/python"
if [ ! -x "$PYTHON" ]; then
  PYTHON="$(command -v python3)"
fi

# Config resolution: explicit JARVIS_CONFIG wins; otherwise prefer the
# user-owned config outside the repo, falling back to the repo default.
if [ -z "${JARVIS_CONFIG:-}" ] && [ -f "$HOME/.jarvis/jarvis.toml" ]; then
  JARVIS_CONFIG="$HOME/.jarvis/jarvis.toml"
  export JARVIS_CONFIG
fi

if [ -n "${JARVIS_CONFIG:-}" ]; then
  JARVIS_CONFIG_REAL="$("$PYTHON" - "$JARVIS_CONFIG" <<'PY'
import sys
from pathlib import Path

print(Path(sys.argv[1]).expanduser().resolve(strict=False))
PY
)"
  JARVIS_EXAMPLE_REAL="$("$PYTHON" - "$JARVIS_REPO/config/jarvis.example.toml" <<'PY'
import sys
from pathlib import Path

print(Path(sys.argv[1]).expanduser().resolve(strict=False))
PY
)"
  if [ "$JARVIS_CONFIG_REAL" = "$JARVIS_EXAMPLE_REAL" ]; then
    echo "config/jarvis.example.toml is not a runtime config." >&2
    echo "Use ~/.jarvis/jarvis.toml or $JARVIS_REPO/config/jarvis.toml." >&2
    exit 1
  fi
fi

exec "$PYTHON" -m jarvis.cli daemon run "$@"
